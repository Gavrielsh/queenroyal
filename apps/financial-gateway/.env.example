# ── financial-gateway — Phase 1 (transport + logging only) ──────────────────────
# Copy to .env and adjust. Every variable is Zod-validated at boot (fail closed): an
# invalid value refuses to start the process.

# development | test | production
NODE_ENV=development

# Bind address / port. Use 0.0.0.0 in a container, 127.0.0.1 for local-only.
HOST=0.0.0.0
PORT=8080

# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Absolute graceful-shutdown drain budget (ms) before server.ts force-exits non-zero. Set this
# below the orchestrator's pod eviction grace period (e.g. Kubernetes terminationGracePeriodSeconds).
SHUTDOWN_TIMEOUT_MS=15000

# Comma-separated browser origins allowed by CORS. Leave EMPTY for no cross-origin
# browser access (server-to-server / webhooks only) — the safe gateway default.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Max request body size in bytes (default 1 MiB). Webhooks are small; keep this tight.
BODY_LIMIT_BYTES=1048576

# ── Database (Postgres via Prisma) ───────────────────────────────────────────────
# Runtime / pooled URL. Behind PgBouncer (transaction mode) in prod, append ?pgbouncer=true
# (and tune connection_limit), e.g.
#   postgresql://user:pass@pgbouncer:6432/queenroyal?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://user:pass@localhost:5432/queenroyal?schema=public
# Direct, NON-pooled connection for `prisma migrate`/introspect ONLY (bypasses PgBouncer).
# Point this at Postgres directly (session mode), NOT the pooler. Optional at runtime.
# DIRECT_DATABASE_URL=postgresql://user:pass@localhost:5432/queenroyal?schema=public

# ── Redis (distributed state: replay nonces, rate limiting, circuit breaker) ──────
# FAIL CLOSED: when Redis is unreachable the protected paths return 503 — there is NO
# in-process fallback. src/lib/redis.ts picks the topology at boot:
#
#   1) HA / Sentinel (PREFERRED in staging+prod) — set REDIS_SENTINELS and ioredis will
#      discover the current master named REDIS_MASTER_NAME and follow it across failover.
#      Comma-separated host:port list (port defaults to 26379):
# REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_MASTER_NAME=qrmaster
# REDIS_PASSWORD=qr_redis_dev_pw            # auth to the master/replicas (requirepass)
# REDIS_SENTINEL_PASSWORD=                  # optional: auth to the sentinels themselves
#
#   2) Standalone (single-node dev) — used ONLY when REDIS_SENTINELS is unset:
# REDIS_URL=redis://localhost:6379

# ── Day-2 ops: global rate limiting, metrics, admin DLQ API ───────────────────────
# Coarse per-IP DoS guard (@fastify/rate-limit), distributed via Redis across pods. Over-limit
# → 429. /api/health and /metrics are never throttled.
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_SECONDS=60
# Prometheus metrics are exposed UNAUTHENTICATED at GET /metrics — keep it internal-only.
# Outbox retention sweeper: SUCCEEDED engine_request_log rows older than this many days
# (by updatedAt) are hard-deleted; PENDING/FAILED/ABANDONED rows are always kept.
RETENTION_MAX_AGE_DAYS=30
# Sweep cadence in ms (default 24h).
RETENTION_SWEEP_INTERVAL_MS=86400000
# Admin DLQ API (GET /api/admin/dlq, POST /api/admin/dlq/:id/replay) auth: HS256 secret for
# ADMIN JWTs (Authorization: Bearer <jwt> carrying role:"admin"). Min 16 chars; keep it
# DISTINCT from JWT_SECRET. UNSET → the admin surface is locked (403, fail closed).
# ADMIN_JWT_SECRET=
# Admin token lifetime (short — operator actions only).
ADMIN_JWT_TTL=15m

# ── Reserved for later migration phases (NOT read yet) ────────────────────────────
# Added to the Zod env schema only when the code that consumes them lands:
#   ENGINE_BASE_URL=https://engine.internal
#   ENGINE_OPERATOR_CODE=...
#   ENGINE_SECRET_KEY=...
#   PROVIDER_WEBHOOK_SECRETS={"pragmatic":"..."}
