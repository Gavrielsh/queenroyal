{
  "name": "@queenroyal/financial-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Fastify zero-financial-state gateway extracted from the Next.js Cashier. Holds NO money: it authenticates, validates, signs, and forwards to the Go 'True Engine' ledger.",
  "license": "UNLICENSED",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
