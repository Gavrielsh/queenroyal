# ──────────────────────────────────────────────────────────────────────────
# Gateway & Cashier — environment template. Copy to `.env` and fill in.
# ──────────────────────────────────────────────────────────────────────────

# Local Gateway DB — Identity / KYC / store catalog / intent journal ONLY. Never balances.
# For serverless, cap driver connections (e.g. ?connection_limit=1) and/or front with a
# pooler (PgBouncer / Prisma Accelerate) to avoid exhausting Postgres max_connections.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/queenroyal?schema=public"

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-at-least-16-chars"
# Short-lived access token lifetime ("15m", "900", ...). Keep this small.
JWT_ACCESS_TTL="15m"
# Opaque refresh token lifetime in seconds (default 7 days).
JWT_REFRESH_TTL_SECONDS="604800"
# Redis-backed auth rate limiting (per IP, fixed window).
AUTH_RATE_LIMIT_MAX="10"
AUTH_RATE_LIMIT_WINDOW_SECONDS="60"
# Fallback cap for the in-memory leaky bucket used on the (non-financial) auth path when
# Redis is unavailable — graceful degradation. Keep it tight.
AUTH_DEGRADED_RATE_LIMIT_MAX="3"

# ── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL="info"  # fatal | error | warn | info | debug | trace | silent

# ── Distributed state (REQUIRED in production) ──────────────────────────────
# Backs replay nonces, auth rate limiting, and refresh sessions. FINANCIAL paths (spins,
# webhooks, sessions) FAIL CLOSED (HTTP 503) if Redis is missing/unreachable; NON-financial
# paths (health, auth rate limiting) gracefully degrade. Optional only for single-process
# dev that does not exercise those paths.
REDIS_URL="redis://localhost:6379"

# Redis circuit breaker: trip open after this many consecutive failures, then fail fast
# for this cooldown before a half-open trial. Stops a dead Redis from stalling every route.
REDIS_CB_FAILURE_THRESHOLD="5"
REDIS_CB_COOLDOWN_MS="10000"

# Secret authenticating the internal reconciliation cron endpoint (/api/internal/cron/reconcile).
# When unset, that endpoint is disabled (503).
CRON_SECRET="change-me-internal-cron-secret-at-least-16-chars"
# Interval (ms) for the long-running reconciliation worker (npm run worker:reconcile).
RECONCILER_INTERVAL_MS="15000"

# ── Reconciliation thresholds (operational overrides, no redeploy needed) ────
RECONCILE_BATCH_SIZE="50"
RECONCILE_STALE_AFTER_MS="60000"
RECONCILE_MAX_ATTEMPTS="10"

# ── Outbound: this gateway as an operator of the True Engine ────────────────
ENGINE_BASE_URL="http://localhost:8080"
# Our operator code at the True Engine (sent as X-Operator-Code; selects our secret).
ENGINE_OPERATOR_CODE="QUEENROYAL"
# Shared HMAC secret used to sign every outbound ledger request (X-Signature).
ENGINE_SECRET_KEY="change-me-shared-hmac-secret-at-least-16-chars"
ENGINE_TIMEOUT_MS="8000"

# ── Inbound: per-provider HMAC secrets for B2B game-aggregator webhooks ─────
# JSON object {"CODE":"secret"} (recommended) or CSV "CODE:secret,CODE2:secret2".
PROVIDER_WEBHOOK_SECRETS='{"PRAGMATIC":"change-me-pragmatic-inbound-secret"}'

# ── Payment Service Provider (PSP) ──────────────────────────────────────────
PAYMENT_PROVIDER="mock"  # "mock" (dev/test) | "stripe"
# Required when PAYMENT_PROVIDER=stripe:
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Generic PSP webhook signing secret (used by the mock provider's webhook verifier).
PSP_WEBHOOK_SECRET="change-me-psp-webhook-secret"
