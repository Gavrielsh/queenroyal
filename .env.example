# ──────────────────────────────────────────────────────────────────────────
# Gateway & Cashier — environment template. Copy to `.env` and fill in.
# ──────────────────────────────────────────────────────────────────────────

# Local Gateway DB — Identity / KYC / store catalog ONLY. Never balances.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/queenroyal?schema=public"

# Auth (stateless JWT)
JWT_SECRET="change-me-to-a-long-random-string-at-least-16-chars"
JWT_EXPIRES_IN="7d"

# True Engine (Go ledger) connection
ENGINE_BASE_URL="http://localhost:8080"

# Shared HMAC secret used to sign every outbound ledger request.
# The architecture docs name this ENGINE_SECRET_KEY; ENGINE_SECRET is accepted as an alias.
ENGINE_SECRET_KEY="change-me-shared-hmac-secret-at-least-16-chars"

# Outbound timeout to the True Engine (milliseconds)
ENGINE_TIMEOUT_MS="8000"
