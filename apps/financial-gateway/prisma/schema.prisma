// ─────────────────────────────────────────────────────────────────────────────
// financial-gateway — local datastore (Prisma + Postgres).
//
// HARD RULE (ARCHITECTURE.md / .claude-instructions):
//   This database holds IDENTITY, COMPLIANCE and STORE CATALOG data plus an
//   append-only INTENT JOURNAL (outbox) ONLY. It MUST NOT contain gc_balance,
//   sc_balance, deposits, withdrawals, or any monetary state. The Go "True Engine"
//   is the single source of truth for money.
//
//   Same physical tables as the legacy Next.js app during the migration (identical
//   @@map names and columns). This schema introduces NO structural change, so both
//   Prisma clients can read the shared database until the legacy DB layer is retired.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Direct, non-pooled (session-mode) connection for `prisma migrate`/introspect — a
  // transaction-mode PgBouncer cannot run them. Unused at runtime (see src/lib/prisma.ts).
  directUrl = env("DIRECT_DATABASE_URL")
}

/// A player identity. `id` is the canonical `user_id` the True Engine references.
/// Auth + compliance attributes only — absolutely no financial fields.
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  kycStatus    KycStatus @default(PENDING)
  vipLevel     Int       @default(0)

  // Identity bridge (NOT financial state): the True Engine's own player UUID, returned by
  // POST /api/v1/player/create where our `id` is sent as `external_id`. Every ledger call
  // addresses the player by THIS id, never by our local `id`.
  trueEnginePlayerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🚫 FORBIDDEN by architecture: gc_balance, sc_balance, deposits, withdrawals.

  @@map("users")
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

/// Append-only INTENT JOURNAL (an outbox) — NOT financial state. Records every money
/// intent forwarded to the True Engine so a crash mid-flight is recoverable. Holds no
/// balances: only the deterministic idempotency key, type, status, and refs.
model EngineRequestLog {
  id                    String              @id @default(uuid())
  operatorTransactionId String              @unique // the deterministic key sent to the engine
  type                  EngineRequestType
  status                EngineRequestStatus @default(PENDING)
  playerId              String? // the engine player_id this intent targets
  providerRef           String? // upstream ref the key was derived from (provider txn / payment_ref)
  ledgerTransactionId   String? // engine-assigned id once the call succeeds
  requestPayload        Json? // exact engine body, stored JSONB for verbatim idempotent replay
  retryable             Boolean             @default(false) // last failure was retryable (409/5xx/timeout)
  attempts              Int                 @default(0) // reconciler attempt counter (bounded)
  lastError             String? // last engine error code/message (diagnostics)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  // Hot path for the outbox claim: scan unfinished work oldest-first by (status, updatedAt).
  @@index([status, updatedAt])
  @@index([createdAt])
  @@map("engine_request_log")
}

enum EngineRequestType {
  BET
  WIN
  DEPOSIT
  ROLLBACK
  PLAYER_CREATE
}

enum EngineRequestStatus {
  PENDING // in-flight, or crashed mid-call (re-claimed once stale)
  SUCCEEDED // committed at the ledger
  FAILED // last attempt failed; eligible for reconciliation
  COMPENSATED // a terminally-failed WIN whose originating BET was rolled back
  ABANDONED // gave up (max attempts) or terminal with nothing to compensate
}

/// Fiat purchase catalog. Pricing METADATA only (no balances).
model StorePackage {
  id            String   @id // e.g. "pkg_value_20"
  label         String
  priceUsdCents Int // integer USD cents charged by the PSP
  gc            Int // Gold Coins granted (integer, whole coins)
  sc            Int // Sweeps Coins granted as SC_Unplayed (integer, whole coins)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("store_packages")
}
