# ── financial-gateway — Phase 1 (transport + logging only) ──────────────────────
# Copy to .env and adjust. Every variable is Zod-validated at boot (fail closed): an
# invalid value refuses to start the process.

# development | test | production
NODE_ENV=development

# Bind address / port. Use 0.0.0.0 in a container, 127.0.0.1 for local-only.
HOST=0.0.0.0
PORT=8080

# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Comma-separated browser origins allowed by CORS. Leave EMPTY for no cross-origin
# browser access (server-to-server / webhooks only) — the safe gateway default.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Max request body size in bytes (default 1 MiB). Webhooks are small; keep this tight.
BODY_LIMIT_BYTES=1048576

# ── Database (Postgres via Prisma) ───────────────────────────────────────────────
# Runtime / pooled URL. Behind PgBouncer (transaction mode) in prod, append ?pgbouncer=true
# (and tune connection_limit), e.g.
#   postgresql://user:pass@pgbouncer:6432/queenroyal?pgbouncer=true&connection_limit=1
DATABASE_URL=postgresql://user:pass@localhost:5432/queenroyal?schema=public
# Direct, NON-pooled connection for `prisma migrate`/introspect ONLY (bypasses PgBouncer).
# Point this at Postgres directly (session mode), NOT the pooler. Optional at runtime.
# DIRECT_DATABASE_URL=postgresql://user:pass@localhost:5432/queenroyal?schema=public

# ── Reserved for later migration phases (NOT read yet) ────────────────────────────
# Added to the Zod env schema only when the code that consumes them lands:
#   REDIS_URL=redis://localhost:6379          # required; limiter & replay store fail closed
#   ENGINE_BASE_URL=https://engine.internal
#   ENGINE_OPERATOR_CODE=...
#   ENGINE_SECRET_KEY=...
#   PROVIDER_WEBHOOK_SECRETS={"pragmatic":"..."}
