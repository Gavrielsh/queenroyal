// ─────────────────────────────────────────────────────────────────────────────
// Gateway & Cashier — local datastore.
//
// HARD RULE (ARCHITECTURE.md / .claude-instructions):
//   This database holds IDENTITY, COMPLIANCE and STORE CATALOG data ONLY.
//   It MUST NOT contain gc_balance, sc_balance, deposits, withdrawals, or any
//   monetary state. The Go "True Engine" is the single source of truth for money.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A player identity. `id` is the canonical `user_id` the True Engine references.
/// Auth + compliance attributes only — absolutely no financial fields.
model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  kycStatus    KycStatus @default(PENDING)
  vipLevel     Int       @default(0)

  // Identity bridge (NOT financial state): the True Engine's own player UUID, returned
  // by POST /api/v1/player/create where our `id` is sent as `external_id`. Every ledger
  // call addresses the player by THIS id, never by our local `id`.
  trueEnginePlayerId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🚫 FORBIDDEN by architecture: gc_balance, sc_balance, deposits, withdrawals.
  //    All balances are owned by the True Engine (Go) — never mirrored here.

  @@map("users")
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

/// Append-only INTENT JOURNAL (an outbox) — NOT financial state. Records every
/// money intent forwarded to the True Engine so a crash between PSP capture and the
/// ledger credit (or between a bet and its win) is recoverable by reconciliation.
/// Holds no balances: only the deterministic idempotency key, type, status, and refs.
model EngineRequestLog {
  id                    String              @id @default(uuid())
  operatorTransactionId String              @unique // the deterministic key sent to the engine
  type                  EngineRequestType
  status                EngineRequestStatus @default(PENDING)
  playerId              String? // the engine player_id this intent targets
  providerRef           String? // upstream ref the key was derived from (provider txn / payment_ref)
  ledgerTransactionId   String? // engine-assigned id once the call succeeds
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([status])
  @@map("engine_request_log")
}

enum EngineRequestType {
  BET
  WIN
  DEPOSIT
  ROLLBACK
  PLAYER_CREATE
}

enum EngineRequestStatus {
  PENDING
  SUCCEEDED
  FAILED
}

/// Fiat purchase catalog. Pricing METADATA only (no balances).
/// Seeded from `src/config/store-packages.ts`, which is the code source of truth.
model StorePackage {
  id            String   @id // e.g. "pkg_value_20"
  label         String
  priceUsdCents Int // integer USD cents charged by the PSP
  gc            Int // Gold Coins granted (integer, whole coins)
  sc            Int // Sweeps Coins granted as SC_Unplayed (integer, whole coins)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("store_packages")
}
